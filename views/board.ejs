<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Tablero — <%= board.name %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --bg: #0f0f11;
        --bg2: #1a1a1e;
        --bg3: #232329;
        --bg4: #2c2c35;
        --border: rgba(255, 255, 255, 0.08);
        --border2: rgba(255, 255, 255, 0.14);
        --text: #f0f0f0;
        --text2: #9b9ba8;
        --text3: #5c5c6e;
        --col-w: 292px;
        --radius: 12px;
        --radius-sm: 8px;
        --ff: 'Syne', sans-serif;
      }
      body {
        font-family: var(--ff);
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        height: 52px;
        background: var(--bg2);
        border-bottom: 0.5px solid var(--border);
        flex-shrink: 0;
      }
      .nav-logo {
        font-size: 15px;
        font-weight: 700;
        letter-spacing: -0.5px;
        color: var(--text);
      }
      .nav-logo span {
        color: #7f77dd;
      }
      .nav-center {
        display: flex;
        gap: 4px;
      }
      .nav-tab {
        font-family: var(--ff);
        font-size: 13px;
        font-weight: 500;
        color: var(--text2);
        padding: 6px 14px;
        border-radius: var(--radius-sm);
        border: none;
        background: transparent;
        cursor: pointer;
        transition:
          background 0.15s,
          color 0.15s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .nav-tab:hover {
        background: var(--bg3);
        color: var(--text);
      }
      .nav-tab.active {
        background: var(--bg4);
        color: var(--text);
      }
      .nav-right {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .nav-avatars {
        display: flex;
      }
      .nav-av {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        font-size: 11px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid var(--bg2);
        margin-left: -7px;
        cursor: pointer;
      }
      .btn {
        font-family: var(--ff);
        font-size: 13px;
        font-weight: 500;
        padding: 6px 16px;
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition:
          opacity 0.15s,
          background 0.15s;
        border: none;
      }
      .btn-ghost {
        background: var(--bg3);
        color: var(--text2);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .btn-ghost:hover {
        background: var(--bg4);
        color: var(--text);
      }
      .btn-accent {
        background: #7f77dd;
        color: #fff;
      }
      .btn-accent:hover {
        opacity: 0.88;
      }
      .toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 24px;
        flex-shrink: 0;
        border-bottom: 0.5px solid var(--border);
      }
      .board-title-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .board-title {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: -0.5px;
      }
      .board-badge {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 10px;
        border-radius: 20px;
        background: rgba(127, 119, 221, 0.18);
        color: #afa9ec;
        border: 0.5px solid rgba(127, 119, 221, 0.3);
      }
      .toolbar-right {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      .search-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--bg3);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 0 12px;
        height: 34px;
      }
      .search-wrap input {
        font-family: var(--ff);
        background: transparent;
        border: none;
        outline: none;
        font-size: 13px;
        color: var(--text);
        width: 160px;
      }
      .search-wrap input::placeholder {
        color: var(--text3);
      }
      .icon-btn {
        width: 34px;
        height: 34px;
        border-radius: var(--radius-sm);
        border: 0.5px solid var(--border);
        background: var(--bg3);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.15s;
        font-size: 15px;
      }
      .icon-btn:hover {
        background: var(--bg4);
      }
      .board-wrap {
        flex: 1;
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .board-scroll {
        display: flex;
        gap: 14px;
        padding: 20px 24px;
        overflow-x: auto;
        overflow-y: hidden;
        align-items: flex-start;
        flex: 1;
        scrollbar-width: thin;
        scrollbar-color: var(--bg4) transparent;
      }
      .board-scroll::-webkit-scrollbar {
        height: 6px;
      }
      .board-scroll::-webkit-scrollbar-track {
        background: transparent;
      }
      .board-scroll::-webkit-scrollbar-thumb {
        background: var(--bg4);
        border-radius: 3px;
      }
      .col {
        min-width: var(--col-w);
        width: var(--col-w);
        flex-shrink: 0;
        background: var(--bg2);
        border-radius: var(--radius);
        border: 0.5px solid var(--border);
        display: flex;
        flex-direction: column;
        max-height: calc(100vh - 170px);
      }
      .col-header {
        padding: 14px 14px 10px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .col-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        background: #7f77dd;
      }
      .col-name {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        flex: 1;
        color: var(--text);
      }
      .col-count {
        font-size: 11px;
        font-weight: 600;
        background: var(--bg4);
        border-radius: 12px;
        padding: 1px 8px;
        color: var(--text2);
      }
      .col-options {
        font-family: var(--ff);
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 17px;
        color: var(--text3);
        padding: 0 4px;
        line-height: 1;
      }
      .col-options:hover {
        color: var(--text2);
      }
      .col-progress {
        padding: 0 14px 8px;
      }
      .progress-bar {
        height: 2px;
        background: var(--bg4);
        border-radius: 2px;
        overflow: hidden;
      }
      .progress-fill {
        height: 100%;
        border-radius: 2px;
        transition: width 0.4s;
        background: #7f77dd;
      }
      .col-cards {
        padding: 0 10px;
        overflow-y: auto;
        flex: 1;
        min-height: 60px;
        scrollbar-width: thin;
        scrollbar-color: var(--bg4) transparent;
      }
      .col-cards::-webkit-scrollbar {
        width: 4px;
      }
      .col-cards::-webkit-scrollbar-thumb {
        background: var(--bg4);
        border-radius: 2px;
      }
      .col-footer {
        padding: 8px 10px 12px;
      }
      .btn-add {
        font-family: var(--ff);
        width: 100%;
        padding: 8px 10px;
        background: transparent;
        border: 0.5px solid transparent;
        border-radius: var(--radius-sm);
        color: var(--text3);
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition:
          background 0.15s,
          color 0.15s,
          border-color 0.15s;
        text-align: left;
      }
      .btn-add:hover {
        background: var(--bg3);
        color: var(--text2);
        border-color: var(--border);
      }
      .card {
        background: var(--bg3);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 12px;
        margin-bottom: 8px;
        transition:
          border-color 0.15s,
          transform 0.15s;
        user-select: none;
        position: relative;
      }
      .card:hover {
        border-color: var(--border2);
      }
      .card-drag-handle {
        position: absolute;
        top: 8px;
        right: 8px;
        cursor: grab;
        color: var(--text3);
        font-size: 14px;
        padding: 2px 4px;
        line-height: 1;
      }
      .card-drag-handle:hover {
        color: var(--text2);
      }
      .card-drag-handle:active {
        cursor: grabbing;
      }
      .card.is-dragging {
        opacity: 0.5;
        transform: scale(0.98);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
      }
      .col-cards.drag-over {
        background: rgba(127, 119, 221, 0.06);
        border-radius: var(--radius-sm);
      }
      .card.drop-before {
        border-top: 3px solid #7f77dd;
        margin-top: 2px;
      }
      .card.drop-after {
        border-bottom: 3px solid #7f77dd;
        margin-bottom: 2px;
      }
      .card-tags {
        display: flex;
        gap: 5px;
        flex-wrap: wrap;
        margin-bottom: 8px;
      }
      .tag {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.4px;
        padding: 2px 8px;
        border-radius: 20px;
        text-transform: uppercase;
      }
      .tag-blue {
        background: rgba(55, 138, 221, 0.18);
        color: #85b7eb;
        border: 0.5px solid rgba(55, 138, 221, 0.25);
      }
      .tag-teal {
        background: rgba(29, 158, 117, 0.18);
        color: #5dcaa5;
        border: 0.5px solid rgba(29, 158, 117, 0.25);
      }
      .tag-amber {
        background: rgba(239, 159, 39, 0.18);
        color: #fac775;
        border: 0.5px solid rgba(239, 159, 39, 0.25);
      }
      .tag-purple {
        background: rgba(127, 119, 221, 0.18);
        color: #afa9ec;
        border: 0.5px solid rgba(127, 119, 221, 0.25);
      }
      .tag-coral {
        background: rgba(216, 90, 48, 0.18);
        color: #f0997b;
        border: 0.5px solid rgba(216, 90, 48, 0.25);
      }
      .tag-red {
        background: rgba(226, 75, 74, 0.18);
        color: #f09595;
        border: 0.5px solid rgba(226, 75, 74, 0.25);
      }
      .tag-green {
        background: rgba(99, 153, 34, 0.18);
        color: #97c459;
        border: 0.5px solid rgba(99, 153, 34, 0.25);
      }
      .tag-pink {
        background: rgba(212, 83, 126, 0.18);
        color: #ed93b1;
        border: 0.5px solid rgba(212, 83, 126, 0.25);
      }
      .card-title {
        font-size: 13px;
        font-weight: 500;
        color: var(--text);
        line-height: 1.55;
        margin-bottom: 10px;
      }
      .card[data-done="1"] .card-title {
        text-decoration: line-through;
        color: var(--text3);
      }
      .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .card-meta {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .card-date {
        font-size: 11px;
        font-weight: 500;
        padding: 2px 8px;
        border-radius: 20px;
        background: var(--bg4);
        color: var(--text2);
      }
      .card-checks {
        font-size: 11px;
        color: var(--text3);
        display: flex;
        align-items: center;
        gap: 3px;
      }
      .card-checks.all-done {
        color: #5dcaa5;
      }
      .modal-bg {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 200;
        backdrop-filter: blur(4px);
      }
      .modal {
        background: var(--bg2);
        border: 0.5px solid var(--border2);
        border-radius: var(--radius);
        padding: 24px;
        width: 420px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
      }
      .modal-title {
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 18px;
        color: var(--text);
      }
      .form-group {
        margin-bottom: 14px;
      }
      .form-label {
        font-size: 10px;
        font-weight: 700;
        color: var(--text3);
        letter-spacing: 0.6px;
        text-transform: uppercase;
        margin-bottom: 6px;
        display: block;
      }
      .modal-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        margin-top: 18px;
      }
      .archived-section {
        padding: 8px 24px 0;
        font-size: 13px;
      }
      .archived-list {
        list-style: none;
        margin-top: 4px;
      }
      .archived-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 6px 0;
      }
      .archived-list-name {
        font-size: 12px;
        color: var(--text3);
        margin-left: 6px;
      }
      .form-input {
        font-family: var(--ff);
        width: 100%;
        padding: 9px 12px;
        font-size: 13px;
        background: var(--bg3);
        border: 0.5px solid var(--border2);
        border-radius: var(--radius-sm);
        color: var(--text);
        outline: none;
      }
    </style>
  </head>
  <body>
    <!-- NAV del tablero basado en trello-board.html -->
    <nav>
      <div class="nav-logo">flow<span>.</span>board</div>
      <div class="nav-center">
        <a href="/" class="nav-tab">Inicio</a>
        <a href="/boards/<%= board.id %>" class="nav-tab active">Tablero</a>
        <a href="/boards/<%= board.id %>/calendar" class="nav-tab">Calendario</a>
        <a href="/boards/<%= board.id %>/archive" class="nav-tab">Archivadas</a>
      </div>
      <div class="nav-right">
        <div class="nav-avatars">
          <div class="nav-av" style="background:rgba(127,119,221,.3);color:#afa9ec">NK</div>
        </div>
        <a href="/" class="btn btn-ghost">Tableros</a>
        <button class="btn btn-accent" type="button">+ Crear</button>
      </div>
    </nav>

    <!-- TOOLBAR superior del tablero -->
    <div class="toolbar">
      <div class="board-title-wrap">
        <div class="board-title"><%= board.name %></div>
        <div class="board-badge">
          <% if (board.description) { %>
          <%= board.description %>
          <% } else { %>
          Tablero
          <% } %>
        </div>
      </div>
      <div class="toolbar-right">
        <div class="search-wrap">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
            <circle cx="6.5" cy="6.5" r="5" stroke="#5c5c6e" stroke-width="1.5" />
            <path
              d="M10.5 10.5L14 14"
              stroke="#5c5c6e"
              stroke-width="1.5"
              stroke-linecap="round"
            />
          </svg>
          <input
            type="text"
            id="card-filter"
            placeholder="Buscar tarjeta..."
          />
        </div>
        <div class="icon-btn" title="Filtrar">⚡</div>
        <div class="icon-btn" title="Vista">⊞</div>
      </div>
    </div>

    <!-- Área de tablero estilo trello-board.html -->
    <div class="board-wrap">
      <% if (archivedCards && archivedCards.length > 0) { %>
      <section class="archived-section">
        <h2>Tarjetas archivadas</h2>
        <ul class="archived-list">
          <% archivedCards.forEach(function (card) { %>
          <li>
            <div class="archived-card">
              <div>
                <strong><%= card.title %></strong>
                <span class="archived-list-name">en lista: <%= card.list_name %></span>
                <% if (card.labels) { %>
                <span class="card-labels"><%= card.labels %></span>
                <% } %>
              </div>
              <form
                method="POST"
                action="/cards/<%= card.id %>/unarchive"
                class="inline-form"
              >
                <input type="hidden" name="boardId" value="<%= board.id %>" />
                <button type="submit" class="btn-small">Desarchivar</button>
              </form>
            </div>
          </li>
          <% }) %>
        </ul>
      </section>
      <% } %>

      <div class="board-scroll" id="board">
        <% lists.forEach(function (list, ci) { %>
        <% const cardsForList = (cardsByList[list.id] || []); %>

        <div class="col" data-list-id="<%= list.id %>">
          <div class="col-header">
            <div class="col-dot"></div>
            <span class="col-name"><%= list.name %></span>
            <span class="col-count"><%= cardsForList.length %></span>
            <form
              method="POST"
              action="/lists/<%= list.id %>/delete"
              onsubmit="return confirm('¿Eliminar esta lista y todas sus tarjetas?');"
            >
              <input type="hidden" name="boardId" value="<%= board.id %>" />
              <button
                type="button"
                class="col-options"
                title="Eliminar lista"
                onclick="this.closest('form').submit()"
              >
                ×
              </button>
            </form>
          </div>
          <div class="col-progress">
            <% const pct = 0; %>
            <div class="progress-bar">
              <div class="progress-fill" style="width:<%= pct %>%"></div>
            </div>
          </div>

          <div class="col-cards" data-list-id="<%= list.id %>">
            <% cardsForList.forEach(function (card) { %>
            <% const items = (checklistsByCard && checklistsByCard[card.id]) || []; %>
            <% const done = items.filter(i => i.is_done).length; %>
            <% const total = items.length; %>
            <% const labelText = (card.labels || '').trim() || 'Tarea'; %>
            <% const labelLower = labelText.toLowerCase(); %>
            <% 
              let tagClass = 'tag-purple';
              if (labelLower.includes('dise')) {
                tagClass = 'tag-blue';
              } else if (labelLower.includes('dev') || labelLower.includes('desarrollo')) {
                tagClass = 'tag-teal';
              } else if (labelLower.includes('marketing')) {
                tagClass = 'tag-amber';
              } else if (labelLower.includes('bug') || labelLower.includes('error')) {
                tagClass = 'tag-coral';
              } else if (labelLower.includes('qa') || labelLower.includes('test')) {
                tagClass = 'tag-green';
              } else if (labelLower.includes('ux')) {
                tagClass = 'tag-pink';
              }
            %>

            <div
              class="card"
              data-card-id="<%= card.id %>"
              data-title="<%= card.title.toLowerCase() %>"
              data-labels="<%= (card.labels || '').toLowerCase() %>"
              data-desc="<%- (card.description || '').replace(/\"/g, '&quot;') %>"
              data-date="<%= card.due_date ? new Date(card.due_date).toISOString().slice(0, 10) : '' %>"
              data-list-id="<%= list.id %>"
              data-done="<%= card.is_done ? '1' : '0' %>"
            >
              <div
                class="card-drag-handle"
                draggable="true"
                title="Arrastra para mover a otra columna"
              >
                <span aria-hidden="true">⋮⋮</span>
              </div>
              <div class="card-tags">
                <span class="tag <%= tagClass %>"><%= labelText %></span>
              </div>
              <div class="card-title"><%= card.title %></div>
              <div class="card-footer">
                <div class="card-meta">
                  <% if (card.due_date) { %>
                  <% const dateStr = new Date(card.due_date).toISOString().slice(0, 10); %>
                  <span class="card-date"><%= dateStr %></span>
                  <% } %>
                  <% if (total > 0) { %>
                  <span class="card-checks <%= done === total ? 'all-done' : '' %>">
                    ✓ <%= done %>/<%= total %>
                  </span>
                  <% } %>
                </div>
                <div style="display:flex;gap:4px;align-items:center">
                  <button
                    type="button"
                    title="Editar tarjeta"
                    style="
                      background: var(--bg3);
                      border: 1px solid var(--border2);
                      color: var(--text3);
                      border-radius: 6px;
                      width: 24px;
                      height: 24px;
                      display: flex;
                      align-items: center;
                      justify-content: center;
                      font-size: 13px;
                      cursor: pointer;
                    "
                    onclick="event.preventDefault(); event.stopPropagation(); openCardEditModal(<%= card.id %>, <%= list.id %>);"
                  >
                    ✎
                  </button>
                  <form
                    method="POST"
                    action="/cards/<%= card.id %>/toggle-done"
                    style="margin:0"
                  >
                    <input type="hidden" name="boardId" value="<%= board.id %>" />
                    <button
                      type="submit"
                      title="Marcar completada"
                      style="
                        background: transparent;
                        border: 1px solid <%= card.is_done ? '#22c55e' : 'var(--border2)' %>;
                        color: <%= card.is_done ? '#22c55e' : 'var(--text3)' %>;
                        border-radius: 6px;
                        width: 24px;
                        height: 24px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 13px;
                        cursor: pointer;
                      "
                    >
                      <%= card.is_done ? '✓' : '' %>
                    </button>
                  </form>
                </div>
              </div>
            </div>
            <% }) %>
          </div>

          <div class="col-footer">
            <form
              method="POST"
              action="/lists/<%= list.id %>/cards"
              class="inline-form"
            >
              <input type="hidden" name="boardId" value="<%= board.id %>" />
              <input
                type="text"
                name="title"
                placeholder="¿Qué hay que hacer?"
                class="form-input"
                style="margin-bottom:6px"
                required
              />
              <div style="display:flex;gap:6px;margin-bottom:6px">
                <input
                  type="date"
                  name="due_date"
                  class="form-input"
                  style="flex:1"
                />
                <input
                  type="text"
                  name="labels"
                  class="form-input"
                  style="flex:1"
                  placeholder="Etiqueta (opcional)"
                />
              </div>
              <button type="submit" class="btn-add">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 12 12"
                  fill="none"
                >
                  <path
                    d="M6 1v10M1 6h10"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                  />
                </svg>
                Agregar tarjeta
              </button>
            </form>
          </div>
        </div>
        <% }) %>

        <!-- Columna para crear lista nueva -->
        <button class="add-col" onclick="document.getElementById('new-list-form').style.display='block'">
          <svg width="14" height="14" viewBox="0 0 12 12" fill="none">
            <path
              d="M6 1v10M1 6h10"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
            />
          </svg>
          Nueva columna
        </button>
      </div>

      <!-- Formulario flotante para nueva lista -->
      <form
        id="new-list-form"
        method="POST"
        action="/boards/<%= board.id %>/lists"
        style="display:none;margin:16px 24px 0;max-width:320px"
      >
        <input
          type="text"
          name="name"
          placeholder="Nombre de la lista"
          class="form-input"
          required
        />
        <div style="margin-top:8px;display:flex;gap:8px;justify-content:flex-end">
          <button
            type="button"
            class="btn btn-ghost"
            onclick="document.getElementById('new-list-form').style.display='none'"
          >
            Cancelar
          </button>
          <button type="submit" class="btn btn-accent">Crear lista</button>
        </div>
      </form>
    </div>

    <!-- MODAL EDITAR TARJETA -->
    <div
      class="modal-bg"
      id="edit-card-modal"
      style="display:none"
      onclick="if(event.target===this)closeCardEditModal()"
    >
      <div class="modal" style="max-width:420px">
        <div class="modal-title">Editar tarjeta</div>
        <form id="edit-card-form" method="POST">
          <input type="hidden" name="boardId" value="<%= board.id %>" />
          <input type="hidden" name="listId" id="edit-card-listId" />
          <div class="form-group">
            <label class="form-label">Título</label>
            <input
              class="form-input"
              id="edit-card-title"
              name="title"
              type="text"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label">Descripción</label>
            <input
              class="form-input"
              id="edit-card-desc"
              name="description"
              type="text"
            />
          </div>
          <div class="form-group">
            <label class="form-label">Etiqueta</label>
            <input
              class="form-input"
              id="edit-card-labels"
              name="labels"
              type="text"
            />
          </div>
          <div class="form-group">
            <label class="form-label">Fecha límite</label>
            <input
              class="form-input"
              id="edit-card-date"
              name="due_date"
              type="date"
            />
          </div>
          <div class="form-group">
            <label class="form-label">Lista</label>
            <select class="form-input" id="edit-card-list-select">
              <% lists.forEach(function (l) { %>
              <option value="<%= l.id %>"><%= l.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="modal-actions">
            <button
              class="btn btn-ghost"
              type="button"
              onclick="closeCardEditModal()"
            >
              Cancelar
            </button>
            <button class="btn btn-accent" type="submit">Guardar cambios</button>
          </div>
        </form>
      </div>
    </div>

    <script>
      let draggedCard = null;

      function clearDropPlaceholders() {
        document.querySelectorAll('.col-cards.drag-over').forEach((el) => el.classList.remove('drag-over'));
        document.querySelectorAll('.card.drop-before, .card.drop-after').forEach((el) => {
          el.classList.remove('drop-before', 'drop-after');
        });
      }

      document.addEventListener('dragstart', (e) => {
        const handle = e.target.closest('.card-drag-handle');
        if (!handle) return;
        const card = handle.closest('.card');
        if (!card) return;
        draggedCard = card;
        card.classList.add('is-dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', card.getAttribute('data-card-id'));
        e.dataTransfer.setDragImage(card, 0, 0);
      });

      document.addEventListener('dragend', () => {
        if (draggedCard) draggedCard.classList.remove('is-dragging');
        clearDropPlaceholders();
        draggedCard = null;
      });

      document.addEventListener('dragover', (e) => {
        const colCards = e.target.closest('.col-cards');
        const cardUnder = e.target.closest('.card');
        if (!colCards) {
          clearDropPlaceholders();
          return;
        }
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';

        colCards.classList.add('drag-over');
        document.querySelectorAll('.col-cards').forEach((c) => {
          if (c !== colCards) c.classList.remove('drag-over');
        });

        document.querySelectorAll('.card').forEach((c) => c.classList.remove('drop-before', 'drop-after'));

        if (cardUnder && cardUnder !== draggedCard) {
          const rect = cardUnder.getBoundingClientRect();
          const mid = rect.top + rect.height / 2;
          if (e.clientY < mid) {
            cardUnder.classList.add('drop-before');
          } else {
            cardUnder.classList.add('drop-after');
          }
        }
      });

      document.addEventListener('dragleave', (e) => {
        if (!e.target.closest('.col-cards')) clearDropPlaceholders();
      });

      document.addEventListener('drop', async (e) => {
        if (!draggedCard) return;

        const colCards = e.target.closest('.col-cards');
        if (!colCards) return;

        e.preventDefault();
        clearDropPlaceholders();
        draggedCard.classList.remove('is-dragging');

        const listId = colCards.getAttribute('data-list-id');
        const cardId = draggedCard.getAttribute('data-card-id');

        let insertBeforeNode = null;
        const cardUnder = e.target.closest('.card');
        if (cardUnder && cardUnder !== draggedCard) {
          const rect = cardUnder.getBoundingClientRect();
          const mid = rect.top + rect.height / 2;
          insertBeforeNode = e.clientY < mid ? cardUnder : cardUnder.nextElementSibling;
        }

        if (insertBeforeNode) {
          colCards.insertBefore(draggedCard, insertBeforeNode);
        } else {
          colCards.appendChild(draggedCard);
        }

        const ids = Array.from(colCards.querySelectorAll('.card[data-card-id]')).map((el) =>
          el.getAttribute('data-card-id')
        );

        try {
          const targetIndex = ids.indexOf(cardId);

          await fetch('/cards/' + cardId + '/move', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ targetListId: listId, targetPosition: targetIndex }),
          });

          await fetch('/lists/' + listId + '/reorder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ cardIds: ids }),
          });
        } catch (err) {
          console.error('Error moviendo tarjeta', err);
        } finally {
          draggedCard = null;
        }
      });

      // Edición de tarjetas
      let editingCardId = null;
      function openCardEditModal(cardId, listId) {
        editingCardId = String(cardId);
        const card = document.querySelector(
          '.card[data-card-id=\"' + String(cardId) + '\"]'
        );
        if (!card) return;
        const title = card.querySelector('.card-title')?.textContent || '';
        const desc = card.getAttribute('data-desc') || '';
        const labels = card.getAttribute('data-labels') || '';
        const date = card.getAttribute('data-date') || '';
        const listIdAttr = listId || card.getAttribute('data-list-id') || '';

        document.getElementById('edit-card-title').value = title;
        document.getElementById('edit-card-desc').value = desc;
        document.getElementById('edit-card-labels').value = labels;
        document.getElementById('edit-card-date').value = date;
        document.getElementById('edit-card-listId').value = listIdAttr;
        const select = document.getElementById('edit-card-list-select');
        if (select) select.value = listIdAttr;

        const form = document.getElementById('edit-card-form');
        form.action = '/cards/' + String(cardId) + '/update';

        document.getElementById('edit-card-modal').style.display = 'flex';
      }
      function closeCardEditModal() {
        document.getElementById('edit-card-modal').style.display = 'none';
        editingCardId = null;
      }

      // Filtro rápido de tarjetas por texto (título o etiqueta)
      const filterInput = document.getElementById('card-filter');
      if (filterInput) {
        filterInput.addEventListener('input', () => {
          const term = filterInput.value.trim().toLowerCase();
          const cards = document.querySelectorAll('.card[data-card-id]');
          cards.forEach((card) => {
            const title = card.getAttribute('data-title') || '';
            const labels = card.getAttribute('data-labels') || '';
            const matches = !term || title.includes(term) || labels.includes(term);
            card.style.display = matches ? '' : 'none';
          });
        });
      }
    </script>
  </body>
</html>

