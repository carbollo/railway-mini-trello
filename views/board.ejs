<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title><%= board.name %> | Mini Trello</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="page">
    <header class="topbar">
      <a href="/" class="back-link">&larr; Tableros</a>
      <h1 class="logo"><%= board.name %></h1>
      <nav class="board-nav">
        <a href="/boards/<%= board.id %>" class="nav-link">Tablero</a>
        <a href="/boards/<%= board.id %>/calendar" class="nav-link">Calendario</a>
        <a href="/boards/<%= board.id %>/archive" class="nav-link">Archivadas</a>
      </nav>
    </header>

    <main class="board">
      <section class="board-header">
        <div class="board-description">
          <% if (board.description) { %>
          <p><%= board.description %></p>
          <% } else { %>
          <p class="board-description-empty">
            Añade una descripción para este tablero (contexto, objetivos, etc.).
          </p>
          <% } %>
        </div>
        <form
          class="board-edit-form"
          method="POST"
          action="/boards/<%= board.id %>/update"
        >
          <input
            type="text"
            name="name"
            value="<%= board.name %>"
            required
          />
          <input
            type="text"
            name="description"
            value="<%= board.description || '' %>"
            placeholder="Descripción del tablero"
          />
          <button type="submit" class="btn-small">Actualizar tablero</button>
        </form>

        <div class="board-filter">
          <input
            type="text"
            id="card-filter"
            placeholder="Filtrar tarjetas por título o etiqueta..."
          />
        </div>
      </section>

      <% if (archivedCards && archivedCards.length > 0) { %>
      <section class="archived-section">
        <h2>Tarjetas archivadas</h2>
        <ul class="archived-list">
          <% archivedCards.forEach(function (card) { %>
          <li>
            <div class="archived-card">
              <div>
                <strong><%= card.title %></strong>
                <span class="archived-list-name">en lista: <%= card.list_name %></span>
                <% if (card.labels) { %>
                <span class="card-labels"><%= card.labels %></span>
                <% } %>
              </div>
              <form
                method="POST"
                action="/cards/<%= card.id %>/unarchive"
                class="inline-form"
              >
                <input type="hidden" name="boardId" value="<%= board.id %>" />
                <button type="submit" class="btn-small">Desarchivar</button>
              </form>
            </div>
          </li>
          <% }) %>
        </ul>
      </section>
      <% } %>

      <section class="lists">
        <% lists.forEach(function (list, listIndex) { %>
        <div class="list-column" data-list-id="<%= list.id %>">
          <div class="list-header">
            <h2><%= list.name %></h2>
            <span class="list-count">
              <%= (cardsByList[list.id] || []).length %>
            </span>
            <form
              method="POST"
              action="/lists/<%= list.id %>/delete"
              onsubmit="return confirm('¿Eliminar esta lista y todas sus tarjetas?');"
            >
              <input type="hidden" name="boardId" value="<%= board.id %>" />
              <button type="submit" class="btn-icon" title="Eliminar lista">×</button>
            </form>
          </div>
          <div class="cards" data-list-id="<%= list.id %>">
            <% (cardsByList[list.id] || []).forEach(function (card) { %>
            <article
              class="card"
              draggable="true"
              data-card-id="<%= card.id %>"
              data-title="<%= card.title.toLowerCase() %>"
              data-labels="<%= (card.labels || '').toLowerCase() %>"
            >
              <div class="card-main">
                <h3><%= card.title %></h3>
                <% if (card.description) { %>
                <p><%= card.description %></p>
                <% } %>
                <div class="card-meta">
                  <% if (card.labels) { %>
                  <span class="card-labels"><%= card.labels %></span>
                  <% } %>
                  <% if (card.due_date) { %>
                  <span class="card-due"
                    >Vence:
                    <%= new Date(card.due_date).toISOString().slice(0, 10) %></span
                  >
                  <% } %>
                  <% const comments = (commentsByCard && commentsByCard[card.id]) || []; %>
                  <% if (comments.length > 0) { %>
                  <span class="card-comments-pill"><%= comments.length %> comentario(s)</span>
                  <% } %>
                  <% const checklistItems = (checklistsByCard && checklistsByCard[card.id]) || []; %>
                  <% if (checklistItems.length > 0) { %>
                  <span class="card-checklist-pill">
                    Checklist <%= checklistItems.filter(i => i.is_done).length %>/<%= checklistItems.length %>
                  </span>
                  <% } %>
                </div>
              </div>
              <div class="card-actions">
                <button
                  type="button"
                  class="btn-small"
                  data-action="toggle-edit"
                  data-card-id="<%= card.id %>"
                >
                  Editar
                </button>
                <form
                  method="POST"
                  action="/cards/<%= card.id %>/archive"
                  onsubmit="return confirm('¿Archivar esta tarjeta?');"
                >
                  <input type="hidden" name="boardId" value="<%= board.id %>" />
                  <button type="submit" class="btn-small">Archivar</button>
                </form>
                <form
                  method="POST"
                  action="/cards/<%= card.id %>/delete"
                  onsubmit="return confirm('¿Eliminar esta tarjeta definitivamente?');"
                >
                  <input type="hidden" name="boardId" value="<%= board.id %>" />
                  <button type="submit" class="btn-danger btn-small">Eliminar</button>
                </form>
              </div>
              <form
                class="card-edit-form hidden"
                method="POST"
                action="/cards/<%= card.id %>/update"
              >
                <input type="hidden" name="boardId" value="<%= board.id %>" />
                <input type="hidden" name="listId" value="<%= list.id %>" />
                <label>
                  Título
                  <input type="text" name="title" value="<%= card.title %>" required />
                </label>
                <label>
                  Descripción
                  <textarea
                    name="description"
                    placeholder="Descripción"
                  ><%= card.description || '' %></textarea>
                </label>
                <label>
                  Etiquetas (separadas por comas)
                  <input
                    type="text"
                    name="labels"
                    value="<%= card.labels || '' %>"
                    placeholder="bug, urgente, mejora"
                  />
                </label>
                <label>
                  Fecha de vencimiento
                  <input
                    type="date"
                    name="due_date"
                    value="<%= card.due_date ? new Date(card.due_date).toISOString().slice(0, 10) : '' %>"
                  />
                </label>
                <button type="submit" class="btn-small">Guardar cambios</button>
              </form>

              <div class="card-extra">
                <div class="card-checklist">
                  <h4>Checklist</h4>
                  <ul>
                    <% const checklistItems2 = (checklistsByCard && checklistsByCard[card.id]) || []; %>
                    <% checklistItems2.forEach(function (item) { %>
                    <li class="<%= item.is_done ? 'checklist-done' : '' %>">
                      <form
                        method="POST"
                        action="/checklists/<%= item.id %>/toggle"
                        class="inline-form"
                      >
                        <input type="hidden" name="boardId" value="<%= board.id %>" />
                        <button type="submit" class="checkbox-btn">
                          <%= item.is_done ? '☑' : '☐' %>
                        </button>
                      </form>
                      <span><%= item.title %></span>
                      <form
                        method="POST"
                        action="/checklists/<%= item.id %>/delete"
                        class="inline-form"
                      >
                        <input type="hidden" name="boardId" value="<%= board.id %>" />
                        <button type="submit" class="btn-icon">×</button>
                      </form>
                    </li>
                    <% }) %>
                  </ul>
                  <form
                    method="POST"
                    action="/cards/<%= card.id %>/checklists"
                    class="inline-form checklist-add-form"
                  >
                    <input type="hidden" name="boardId" value="<%= board.id %>" />
                    <input
                      type="text"
                      name="title"
                      placeholder="Nuevo elemento de checklist"
                    />
                    <button type="submit" class="btn-small">Añadir</button>
                  </form>
                </div>

                <div class="card-comments">
                  <h4>Comentarios</h4>
                  <div class="comments-list">
                    <% const comments2 = (commentsByCard && commentsByCard[card.id]) || []; %>
                    <% comments2.forEach(function (c) { %>
                    <div class="comment">
                      <div class="comment-content"><%= c.content %></div>
                      <div class="comment-meta">
                        <%= new Date(c.created_at).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' }) %>
                      </div>
                    </div>
                    <% }) %>
                    <% if (comments2.length === 0) { %>
                    <p class="comment-empty">Sin comentarios todavía.</p>
                    <% } %>
                  </div>
                  <form
                    method="POST"
                    action="/cards/<%= card.id %>/comments"
                    class="comment-form"
                  >
                    <input type="hidden" name="boardId" value="<%= board.id %>" />
                    <textarea
                      name="content"
                      placeholder="Escribe un comentario..."
                      required
                    ></textarea>
                    <button type="submit" class="btn-small">Comentar</button>
                  </form>
                </div>
              </div>
            </article>
            <% }) %>
          </div>
          <form
            class="card-form"
            method="POST"
            action="/lists/<%= list.id %>/cards"
          >
            <input type="hidden" name="boardId" value="<%= board.id %>" />
            <input
              type="text"
              name="title"
              placeholder="Título de la tarjeta"
              required
            />
            <textarea
              name="description"
              placeholder="Descripción (opcional)"
            ></textarea>
            <input
              type="text"
              name="labels"
              placeholder="Etiquetas (opcional, separadas por comas)"
            />
            <input type="date" name="due_date" />
            <button type="submit">Añadir tarjeta</button>
          </form>
        </div>
        <% }) %>

        <div class="list-column list-new">
          <h2>Nueva lista</h2>
          <form method="POST" action="/boards/<%= board.id %>/lists">
            <input
              type="text"
              name="name"
              placeholder="Nombre de la lista"
              required
            />
            <button type="submit">Crear lista</button>
          </form>
        </div>
      </section>
    </main>

    <script>
      // Drag & Drop simple para mover tarjetas entre listas
      let draggedCard = null;

      document.addEventListener('dragstart', (e) => {
        if (e.target.classList.contains('card')) {
          draggedCard = e.target;
          e.dataTransfer.effectAllowed = 'move';
        }
      });

      document.addEventListener('dragover', (e) => {
        if (e.target.classList.contains('cards') || e.target.classList.contains('card')) {
          e.preventDefault();
        }
      });

      document.addEventListener('drop', async (e) => {
        if (!draggedCard) return;

        const cardsContainer = e.target.closest('.cards');
        if (!cardsContainer) return;

        e.preventDefault();

        const listId = cardsContainer.getAttribute('data-list-id');
        const cardId = draggedCard.getAttribute('data-card-id');

        cardsContainer.appendChild(draggedCard);

        try {
          // Primero movemos la tarjeta a la lista nueva
          await fetch('/cards/' + cardId + '/move', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              targetListId: listId,
            }),
          });

          // Luego enviamos el nuevo orden de tarjetas en esa lista
          const ids = Array.from(
            cardsContainer.querySelectorAll('.card[data-card-id]')
          ).map((el) => el.getAttribute('data-card-id'));

          await fetch('/lists/' + listId + '/reorder', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ cardIds: ids }),
          });
        } catch (err) {
          console.error('Error moviendo tarjeta', err);
        } finally {
          draggedCard = null;
        }
      });

      // Mostrar / ocultar formulario de edición de tarjeta
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-action="toggle-edit"]');
        if (!btn) return;
        const cardId = btn.getAttribute('data-card-id');
        const cardEl = document.querySelector('.card[data-card-id="' + cardId + '"]');
        if (!cardEl) return;
        const form = cardEl.querySelector('.card-edit-form');
        if (!form) return;
        form.classList.toggle('hidden');
      });

      // Filtro rápido de tarjetas por texto (título o etiquetas)
      const filterInput = document.getElementById('card-filter');
      if (filterInput) {
        filterInput.addEventListener('input', () => {
          const term = filterInput.value.trim().toLowerCase();
          const cards = document.querySelectorAll('.card[data-card-id]');
          cards.forEach((card) => {
            const title = card.getAttribute('data-title') || '';
            const labels = card.getAttribute('data-labels') || '';
            const matches = !term || title.includes(term) || labels.includes(term);
            card.style.display = matches ? '' : 'none';
          });
        });
      }
    </script>
  </body>
</html>

