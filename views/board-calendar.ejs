<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Calendario - <%= board.name %> | Mini Trello</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="page">
    <header class="topbar">
      <a href="/" class="back-link">&larr; Tableros</a>
      <h1 class="logo"><%= board.name %></h1>
      <nav class="board-nav">
        <a href="/boards/<%= board.id %>" class="nav-link">Tablero</a>
        <a href="/boards/<%= board.id %>/calendar" class="nav-link">Calendario</a>
        <a href="/boards/<%= board.id %>/archive" class="nav-link">Archivadas</a>
      </nav>
    </header>

    <main class="board calendar-view">
      <section class="calendar-header">
        <button
          class="btn-small"
          onclick="window.location.href='?month=<%= prevMonthParam %>'"
        >
          ◀
        </button>
        <h2 class="calendar-title"><%= monthLabel %></h2>
        <button
          class="btn-small"
          onclick="window.location.href='?month=<%= nextMonthParam %>'"
        >
          ▶
        </button>
      </section>

      <section class="calendar-grid">
        <div class="calendar-weekdays">
          <div>Lun</div>
          <div>Mar</div>
          <div>Mié</div>
          <div>Jue</div>
          <div>Vie</div>
          <div>Sáb</div>
          <div>Dom</div>
        </div>
        <div class="calendar-cells">
          <% calendarCells.forEach(function (cell, idx) { %>
          <% if (idx % 7 === 0) { %>
          <div class="calendar-week">
            <% } %>
            <div class="calendar-cell <%= cell.inCurrent ? '' : 'calendar-cell-out' %>">
              <% if (cell.inCurrent) { %>
              <div class="calendar-day-number"><%= cell.dayNum %></div>
              <div class="calendar-day-cards">
                <% cell.cards.forEach(function (card) { %>
                <div class="calendar-card">
                  <div class="calendar-card-title"><%= card.title %></div>
                  <div class="calendar-card-meta">
                    <span class="calendar-card-list"><%= card.list_name %></span>
                    <% if (card.labels) { %>
                    <span class="card-labels"><%= card.labels %></span>
                    <% } %>
                  </div>
                </div>
                <% }) %>
              </div>
              <% } %>
            </div>
            <% if (idx % 7 === 6) { %>
          </div>
          <% } %>
          <% }) %>
        </div>
      </section>
    </main>
  </body>
</html>

