<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Calendario — <%= board.name %></title>
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --bg: #0f0f11;
        --bg2: #1a1a1e;
        --bg3: #232329;
        --bg4: #2c2c35;
        --border: rgba(255, 255, 255, 0.08);
        --border2: rgba(255, 255, 255, 0.14);
        --text: #f0f0f0;
        --text2: #9b9ba8;
        --text3: #5c5c6e;
        --accent: #7f77dd;
        --radius: 12px;
        --radius-sm: 8px;
        --ff: 'Syne', sans-serif;
      }
      body {
        font-family: var(--ff);
        background: var(--bg);
        color: var(--text);
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        height: 52px;
        background: var(--bg2);
        border-bottom: 0.5px solid var(--border);
        flex-shrink: 0;
      }
      .nav-logo {
        font-size: 15px;
        font-weight: 700;
        letter-spacing: -0.5px;
      }
      .nav-logo span {
        color: var(--accent);
      }
      .nav-center {
        display: flex;
        gap: 4px;
      }
      .nav-tab {
        font-family: var(--ff);
        font-size: 13px;
        font-weight: 500;
        color: var(--text2);
        padding: 6px 14px;
        border-radius: var(--radius-sm);
        border: none;
        background: transparent;
        cursor: pointer;
        transition:
          background 0.15s,
          color 0.15s;
      }
      .nav-tab:hover {
        background: var(--bg3);
        color: var(--text);
      }
      .nav-tab.active {
        background: var(--bg4);
        color: var(--text);
      }
      .nav-right {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .btn {
        font-family: var(--ff);
        font-size: 13px;
        font-weight: 500;
        padding: 6px 16px;
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition:
          opacity 0.15s,
          background 0.15s;
        border: none;
      }
      .btn-ghost {
        background: var(--bg3);
        color: var(--text2);
      }
      .btn-ghost:hover {
        background: var(--bg4);
        color: var(--text);
      }
      .btn-accent {
        background: var(--accent);
        color: #fff;
      }
      .layout {
        display: flex;
        flex: 1;
        min-height: 0;
        overflow: hidden;
      }
      .cal-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
        overflow: hidden;
      }
      .cal-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 24px;
        border-bottom: 0.5px solid var(--border);
        flex-shrink: 0;
      }
      .cal-nav {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .cal-nav-btn {
        font-family: var(--ff);
        width: 32px;
        height: 32px;
        border-radius: var(--radius-sm);
        border: 0.5px solid var(--border);
        background: var(--bg3);
        color: var(--text2);
        cursor: pointer;
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          background 0.15s,
          color 0.15s;
      }
      .cal-nav-btn:hover {
        background: var(--bg4);
        color: var(--text);
      }
      .cal-month-label {
        font-size: 17px;
        font-weight: 700;
        letter-spacing: -0.5px;
        min-width: 170px;
      }
      .today-btn {
        font-family: var(--ff);
        font-size: 12px;
        font-weight: 600;
        padding: 5px 14px;
        border-radius: var(--radius-sm);
        border: 0.5px solid var(--border2);
        background: transparent;
        color: var(--text2);
        cursor: pointer;
        transition:
          background 0.15s,
          color 0.15s;
      }
      .today-btn:hover {
        background: var(--bg3);
        color: var(--text);
      }
      .cal-view {
        flex: 1;
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .dow-header {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        border-bottom: 0.5px solid var(--border);
        flex-shrink: 0;
      }
      .dow-cell {
        padding: 10px 0;
        text-align: center;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.6px;
        color: var(--text3);
        text-transform: uppercase;
      }
      .cal-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        grid-auto-rows: 1fr;
        flex: 1;
        overflow: hidden;
      }
      .cal-cell {
        border-right: 0.5px solid var(--border);
        border-bottom: 0.5px solid var(--border);
        padding: 8px 8px 6px;
        display: flex;
        flex-direction: column;
        gap: 3px;
        cursor: pointer;
        transition: background 0.15s;
        min-height: 0;
        overflow: hidden;
      }
      .cal-cell.other-month {
        opacity: 0.38;
      }
      .day-num {
        font-size: 12px;
        font-weight: 600;
        color: var(--text2);
        width: 26px;
        height: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .cal-events {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .cal-event {
        font-size: 11px;
        font-weight: 500;
        border-radius: 4px;
        padding: 2px 6px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        cursor: pointer;
        transition: opacity 0.15s;
      }
      .cal-event:hover {
        opacity: 0.8;
      }
      .event-board {
        font-size: 10px;
        color: var(--text3);
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-logo">flow<span>.</span>board</div>
      <div class="nav-center">
        <button
          class="nav-tab"
          onclick="window.location.href='/'"
        >
          Inicio
        </button>
        <button
          class="nav-tab"
          onclick="window.location.href='/boards/<%= board.id %>'"
        >
          Tablero
        </button>
        <button class="nav-tab active">Calendario</button>
      </div>
      <div class="nav-right">
        <button class="btn btn-ghost" type="button" onclick="alert('Próximamente')">
          Compartir
        </button>
      </div>
    </nav>

    <div class="layout">
      <main class="cal-main">
        <div class="cal-toolbar">
          <div class="cal-nav">
            <button
              class="cal-nav-btn"
              onclick="window.location.href='?month=<%= prevMonthParam %>'"
            >
              ‹
            </button>
            <button
              class="cal-nav-btn"
              onclick="window.location.href='?month=<%= nextMonthParam %>'"
            >
              ›
            </button>
            <div class="cal-month-label"><%= monthLabel %></div>
            <button
              class="today-btn"
              type="button"
              onclick="window.location.href='/boards/<%= board.id %>/calendar'"
            >
              Hoy
            </button>
          </div>
        </div>

        <section class="cal-view">
          <div class="dow-header">
            <div class="dow-cell">Lun</div>
            <div class="dow-cell">Mar</div>
            <div class="dow-cell">Mié</div>
            <div class="dow-cell">Jue</div>
            <div class="dow-cell">Vie</div>
            <div class="dow-cell">Sáb</div>
            <div class="dow-cell">Dom</div>
          </div>

          <div class="cal-grid">
            <% calendarCells.forEach(function (cell) { %>
            <div
              class="cal-cell <%= cell.inCurrent ? '' : 'other-month' %>"
            >
              <% if (cell.inCurrent) { %>
              <div class="day-num"><%= cell.dayNum %></div>
              <div class="cal-events">
                <% cell.cards.forEach(function (card) { %>
                <div
                  class="cal-event"
                  style="background:<%=
                    (board && board.folder_color)
                      ? `linear-gradient(135deg, ${board.folder_color}, #020617)`
                      : 'rgba(127,119,221,0.22)'
                  %>; opacity:<%= card.is_done ? 0.55 : 1 %>;"
                >
                  <div>
                    <% if (card.is_done) { %>
                    ✓
                    <% } %>
                    <%= card.title %>
                  </div>
                  <div class="event-board"><%= card.list_name %></div>
                </div>
                <% }) %>
              </div>
              <% } %>
            </div>
            <% }) %>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>

